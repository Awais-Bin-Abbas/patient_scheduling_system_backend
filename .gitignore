# .gitignore

# ─── Python ───────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# ─── Virtual Environment ──────────────────────────
env/
venv/
.venv/
ENV/

# ─── Django ───────────────────────────────────────
*.log
*.pot
*.pyc
db.sqlite3          # Never push your local database
media/
staticfiles/

# ─── Environment Variables ────────────────────────
.env
.env.local
.env.production

# ─── IDE ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─── Docker ───────────────────────────────────────
*.env.docker

# ─── Coverage & Testing ───────────────────────────
.coverage
htmlcov/
.pytest_cache/